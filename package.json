{
  "name": "blood-match-api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "node dist/src/main.js",
    "build": "tsc -p tsconfig.build.json",
    "audit:check": "npm audit --json",
    "start:dev": "nest start --watch",
    "seed:admin": "ts-node -r tsconfig-paths/register src/db/seed-admin.ts",
    "prepare": "[ \"$NODE_ENV\" != \"production\" ] && husky install || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typeorm": "typeorm-ts-node-commonjs -d src/db/datasource.ts",
    "migration:generate": "npm run build && npm run typeorm  -- migration:generate src/migrations/$npm_config_name",
    "migration:run": "typeorm -d dist/src/db/datasource.js migration:run",
    "migration:revert": "typeorm -d dist/src/db/datasource.js migration:revert",
    "migration:create": "npm run typeorm -- migration:create src/migrations/$npm_config_name",
    "migration:show": "npm run typeorm -- migration:show"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "clsx": "2.1.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.19",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "husky": "^8.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ajv": "8.18.0",
    "picomatch": "4.0.4",
    "path-to-regexp": "8.4.0"
  }
}
